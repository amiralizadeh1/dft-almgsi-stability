&CONTROL
   calculation      = 'relax'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = 'qe_tmp'
   prefix           = 'Al31Mg'
   disk_io          = 'low'
   pseudo_dir       = '../../../pseudos'
/
&SYSTEM
   ecutwfc          = 50
   ecutrho          = 400
   occupations      = 'smearing'
   degauss          = 0.02
   smearing         = 'mv'
   input_dft        = 'PBE'
   ntyp             = 2
   nat              = 32
   ibrav            = 0
/
&ELECTRONS
   electron_maxstep = 120
   conv_thr         = 1e-08
/
&IONS
   ion_dynamics     = 'bfgs'
/
&CELL
   press_conv_thr   = 0.5
/
&FCP
/
&RISM
/
